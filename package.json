{
  "name": "southern-ledger",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler dev --local --port 8787",
    "build": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.worker.json && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "types:worker": "wrangler types worker-configuration.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply southern-ledger --local",
    "deploy:prepare": "node scripts/prepare-deploy-config.mjs",
    "deploy:check": "npm run build && npm run deploy:prepare && wrangler deploy --dry-run --config wrangler.deploy.jsonc",
    "deploy:migrate": "npm run deploy:prepare && wrangler d1 migrations apply southern-ledger --remote --config wrangler.deploy.jsonc",
    "deploy": "npm run build && npm run deploy:prepare && wrangler deploy --config wrangler.deploy.jsonc"
  },
  "dependencies": {
    "@types/papaparse": "^5.5.2",
    "@vitejs/plugin-react": "^6.0.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.16.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@eslint/js": "^9.15.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.0.1",
    "wrangler": "^4.90.1"
  }
}
